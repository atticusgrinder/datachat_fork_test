# ===================
# Required
# ===================

# Anthropic API key for Claude access
ANTHROPIC_API_KEY=sk-ant-...

# ===================
# Authentication (Clerk)
# ===================

# Clerk keys for JWT validation
CLERK_SECRET_KEY=sk_...
CLERK_PUBLISHABLE_KEY=pk_...

# Set to "true" to bypass auth in development
DISABLE_AUTH=true

# ===================
# Database
# ===================

# Database connection string (defaults to sqlite:///./datachat.db)
# For production, use PostgreSQL:
DATABASE_URL=postgresql://user:password@host:5432/datachat

# ===================
# Security
# ===================

# Encryption key for warehouse credentials (change in production!)
ENCRYPTION_KEY=dev-encryption-key-change-in-production

# ===================
# CORS
# ===================

# Comma-separated allowed origins (defaults to "*")
ALLOWED_ORIGINS=http://localhost:8080,https://yourdomain.com

# ===================
# Email Notifications (Resend)
# ===================

# Resend API key for sending consulting inquiry emails (optional)
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=hello@datachat.app
RESEND_FROM_EMAIL=datachat <onboarding@resend.dev>

# ===================
# Demo Mode
# ===================

# MotherDuck token and database for public demo (optional)
DEMO_MOTHERDUCK_TOKEN=your-motherduck-token
DEMO_MOTHERDUCK_DATABASE=sample_data

