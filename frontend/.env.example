# Backend API URL.
# Local dev: http://localhost:8000
# Production: your backend's public URL (e.g. https://api.yourdomain.com)
VITE_API_URL=http://localhost:8000

# Clerk publishable key (starts with pk_test_ or pk_live_).
# Get this from https://dashboard.clerk.com → API Keys.
# Leave blank if you set DISABLE_AUTH=true on the backend.
VITE_CLERK_PUBLISHABLE_KEY=
